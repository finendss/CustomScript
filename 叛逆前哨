local flightData = {
    isFlying = false,
    speed = 50,
    originalGravity = nil,
    originalWalkSpeed = nil,
    connection = nil
}

local player = game.Players.LocalPlayer

local function startFlight()
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    flightData.originalGravity = workspace.Gravity
    flightData.originalWalkSpeed = humanoid.WalkSpeed
    
    workspace.Gravity = 0
    humanoid.WalkSpeed = flightData.speed
    humanoid.PlatformStand = true
    
    local rootPart = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not rootPart then return end
    
    if flightData.connection then
        flightData.connection:Disconnect()
        flightData.connection = nil
    end
    
    flightData.connection = RunService.Heartbeat:Connect(function()
        if not flightData.isFlying then return end
        
        local currentChar = player.Character
        if not currentChar then return end
        
        local currentHumanoid = currentChar:FindFirstChild("Humanoid")
        if not currentHumanoid then return end
        
        local currentRoot = currentChar:FindFirstChild("HumanoidRootPart") or currentChar:FindFirstChild("Torso")
        if not currentRoot then return end
        
        local moveDirection = currentHumanoid.MoveDirection
        
        if moveDirection.Magnitude > 0 then
            currentChar:TranslateBy(moveDirection * flightData.speed * 0.1)
            currentRoot.CFrame = CFrame.lookAt(currentRoot.Position, currentRoot.Position + moveDirection)
        end
    end)
end

local function stopFlight()
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            if flightData.originalGravity then
                workspace.Gravity = flightData.originalGravity
                flightData.originalGravity = nil
            end
            if flightData.originalWalkSpeed then
                humanoid.WalkSpeed = flightData.originalWalkSpeed
                flightData.originalWalkSpeed = nil
            end
            humanoid.PlatformStand = false
        end
    end
    
    if flightData.connection then
        flightData.connection:Disconnect()
        flightData.connection = nil
    end
end

