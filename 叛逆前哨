Tab2:Section({Title = "玩家绘制", TextXAlignment = "Left", TextSize = 17})

local localPlayer = Players.LocalPlayer
local espEnabled = false
local boxEnabled = false
local nameEnabled = false
local espConnection = nil

local espFolder = Instance.new("Folder")
espFolder.Name = "ESPFolder"
espFolder.Parent = workspace

local function clearESP()
    espFolder:ClearAllChildren()
end

local function createESP(targetPlayer)
    local char = targetPlayer.Character
    if not char then return end
    
    local head = char:FindFirstChild("Head")
    local humanoid = char:FindFirstChild("Humanoid")
    if not head or not humanoid or humanoid.Health <= 0 then return end
    
    local playerFolder = Instance.new("Folder")
    playerFolder.Name = targetPlayer.Name
    playerFolder.Parent = espFolder

    if nameEnabled then
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "NameTag"
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.MaxDistance = 500
        billboard.Adornee = head
        billboard.Parent = playerFolder

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        textLabel.TextStrokeTransparency = 0
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Font = Enum.Font.SourceSansBold
        textLabel.TextScaled = true
        textLabel.Text = targetPlayer.Name
        textLabel.Parent = billboard
    end

    if boxEnabled then
        local highlight = Instance.new("Highlight")
        highlight.Name = "Box"
        highlight.Adornee = char
        highlight.FillColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 1
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineTransparency = 0
        highlight.Parent = playerFolder
    end
end

local function updateESP()
    clearESP()
    
    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= localPlayer and targetPlayer.Character then
            pcall(createESP, targetPlayer)
        end
    end
end

local function startESP()
    if espConnection then
        espConnection:Disconnect()
        espConnection = nil
    end
    espConnection = RunService.RenderStepped:Connect(function()
        updateESP()
    end)
end

local function stopESP()
    if espConnection then
        espConnection:Disconnect()
        espConnection = nil
    end
    clearESP()
end

local function checkESPState()
    if boxEnabled or nameEnabled then
        if not espConnection then
            startESP()
        end
    else
        if espConnection then
            stopESP()
        end
    end
end

Tab2:Toggle({
