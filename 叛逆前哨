Tab:Section({Title = "载具飞行", TextXAlignment = "Left", TextSize = 17})

local vehicleFlightData = {
    isFlying = false,
    speed = 50,
    bodyVelocity = nil,
    bodyGyro = nil
}

local function getVehicleRoot()
    local char = player.Character
    if not char then return nil end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return nil end
    local seat = humanoid.SeatPart
    if seat then
        local vehicle = seat.Parent
        return vehicle:FindFirstChildWhichIsA("BasePart") or vehicle.PrimaryPart
    end
    return nil
end

local function clearVehicleMovers()
    if vehicleFlightData.bodyVelocity then
        vehicleFlightData.bodyVelocity:Destroy()
        vehicleFlightData.bodyVelocity = nil
    end
    if vehicleFlightData.bodyGyro then
        vehicleFlightData.bodyGyro:Destroy()
        vehicleFlightData.bodyGyro = nil
    end
end

local function applyVehicleFly(direction)
    if not vehicleFlightData.isFlying then return end
    local root = getVehicleRoot()
    if not root then return end

    clearVehicleMovers()

    local BV = Instance.new("BodyVelocity", root)
    local BG = Instance.new("BodyGyro", root)
    BG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    BG.D = 5000
    BG.P = 50000
    BG.CFrame = workspace.CurrentCamera.CFrame
    BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    
    vehicleFlightData.bodyVelocity = BV
    vehicleFlightData.bodyGyro = BG

    if direction then
        BV.Velocity = direction * vehicleFlightData.speed
    end
end

local function stopVehicleFly()
    vehicleFlightData.isFlying = false
    clearVehicleMovers()
    local root = getVehicleRoot()
    if root then
        root.Anchored = false
    end
end

